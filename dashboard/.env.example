# Where `vite dev` proxies /api and /health to (your running backend).
#  - docker compose stack (via nginx):  http://localhost
#  - local `go run ./cmd/api`:           http://localhost:8080
VITE_PROXY_TARGET=http://localhost

# Optional: call the backend at an absolute URL instead of the dev proxy.
# Leave empty to use the proxy (recommended for dev). Requires backend CORS.
# VITE_API_BASE=http://localhost
