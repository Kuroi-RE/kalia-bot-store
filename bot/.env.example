# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=123456:ABC-your-bot-token

# Backend base URL (no trailing slash).
#  - local (go run ./cmd/api):        http://localhost:8080
#  - docker compose (via nginx):      http://localhost
#  - inside the compose network:      http://api:8080
BACKEND_URL=http://localhost:8080

# Must match BOT_SERVICE_TOKEN in the backend .env
BOT_SERVICE_TOKEN=dev-bot-service-token

# Command that opens the product catalog (without leading slash).
ORDER_COMMAND=order

# Auto-poll a pending order for status changes.
POLL_INTERVAL_MS=10000
POLL_MAX_ATTEMPTS=90
