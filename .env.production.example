# ============================================================
# Production environment for the VPS deployment.
# Copy to ".env" on the server:  cp .env.production.example .env
# Fill EVERY value below. Never commit the real .env (it is gitignored).
# ============================================================

# ---- App ----
APP_ENV=production
HTTP_PORT=8080
LOG_LEVEL=info

# ---- TLS / domain (used by Caddy) ----
# DNS A record for this domain must point to the VPS public IP.
API_DOMAIN=api.your-domain.com
# Email for Let's Encrypt expiry notices.
ACME_EMAIL=you@your-domain.com

# ---- Database (Supabase) ----
# Use the DIRECT / session connection (port 5432), NOT the transaction
# pooler (6543): pgx caches prepared statements which breaks in
# transaction-pooling mode, and DB migrations run on API startup.
# sslmode=require is mandatory for Supabase.
DATABASE_URL=postgres://postgres.<project-ref>:<db-password>@aws-0-<region>.pooler.supabase.com:5432/postgres?sslmode=require

# ---- Auth ----
# Generate with:  openssl rand -base64 48
JWT_SECRET=REPLACE_WITH_LONG_RANDOM_STRING
JWT_TTL=24h

# Seeded on first startup if the admin table is empty.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=REPLACE_WITH_STRONG_PASSWORD

# ---- CORS ----
# Restrict to the Vercel dashboard origin. Never use "*" in production.
CORS_ALLOWED_ORIGINS=https://your-dashboard.vercel.app

# ---- Bot ----
# Static token the bot presents on /bot/* endpoints (must match the bot).
# Generate with:  openssl rand -hex 32
BOT_SERVICE_TOKEN=REPLACE_WITH_RANDOM_TOKEN
# Telegram Bot API token from @BotFather (used by BOTH the backend delivery
# client and the Telegraf bot).
TELEGRAM_BOT_TOKEN=REPLACE_WITH_TELEGRAM_BOT_TOKEN
# Command that opens the catalog (bot side).
ORDER_COMMAND=order

# ---- Reservation / payment TTLs ----
RESERVATION_TTL=15m
PAYMENT_TTL=15m

# ---- Midtrans (production) ----
PAYMENT_MODE=midtrans
MIDTRANS_SERVER_KEY=Mid-server-REPLACE_WITH_PRODUCTION_KEY
MIDTRANS_BASE_URL=https://api.midtrans.com
MIDTRANS_ACQUIRER=gopay

# ---- Worker cadence (optional; defaults are fine) ----
WORKER_POLL_INTERVAL=90s
WORKER_CLEANUP_INTERVAL=2m
WORKER_DELIVERY_RETRY_INTERVAL=3m
WORKER_MAX_DELIVERY_ATTEMPTS=5
WORKER_BATCH_LIMIT=100
