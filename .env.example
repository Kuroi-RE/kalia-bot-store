# ---- App ----
APP_ENV=development
HTTP_PORT=8080
LOG_LEVEL=info

# ---- Database ----
# For local (non-docker) runs point at localhost; docker-compose overrides host to "postgres".
DATABASE_URL=postgres://kalia:kalia@localhost:5432/kalia_store?sslmode=disable
POSTGRES_USER=kalia
POSTGRES_PASSWORD=kalia
POSTGRES_DB=kalia_store

# ---- Auth ----
# Generate a long random string in production.
JWT_SECRET=change-me-to-a-long-random-secret
JWT_TTL=24h

# Admin bootstrap credentials (seeded on first startup if the admin table is empty).
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me

# ---- Bot ----
# Static token the Telegram bot presents on /bot/* endpoints.
BOT_SERVICE_TOKEN=change-me-bot-service-token
# Telegram Bot API token (backend -> Telegram delivery of credentials).
TELEGRAM_BOT_TOKEN=

# ---- Reservation / payment TTLs ----
RESERVATION_TTL=15m
PAYMENT_TTL=15m

# ---- Midtrans ----
MIDTRANS_SERVER_KEY=SB-Mid-server-xxxxxxxxxxxxxxxx
MIDTRANS_BASE_URL=https://api.sandbox.midtrans.com
MIDTRANS_ACQUIRER=gopay

# Payment mode: "midtrans" (default) or "fake" for local development without a
# Midtrans account. When "fake", a dev settle endpoint is enabled at
# /api/v1/dev/settle/:order_ref. NEVER set "fake" in production.
PAYMENT_MODE=midtrans
